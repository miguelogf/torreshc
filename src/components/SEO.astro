---
interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string;
  type?: 'website' | 'article';
}

const {
  title,
  description,
  image = '/favicon.svg',
  canonicalURL = Astro.url.href,
  type = 'website',
} = Astro.props;

const siteUrl = 'https://torreshc.com';
const absoluteImage = image.startsWith('http') ? image : new URL(image, siteUrl).href;
const formattedTitle = `${title} | Torres Home`;
---

<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />

<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={formattedTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={absoluteImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content="Torres Home" />
<meta property="og:locale" content="en_US" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={formattedTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={absoluteImage} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Torres Home",
  "url": siteUrl,
  "description": description,
  "telephone": "+1-704-968-8289",
  "email": "info@torreshc.com",
  "address": {
    "@type": "PostalAddress",
    "addressRegion": "NC",
    "addressCountry": "US"
  },
  "areaServed": {
    "@type": "State",
    "name": "North Carolina"
  },
  "priceRange": "$$",
  "image": absoluteImage,
  "sameAs": [
    "https://www.facebook.com/jeanpaul.ocampotorres",
    "https://www.instagram.com/jpaul.torres"
  ]
})} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Torres Home",
  "url": siteUrl,
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": `${siteUrl}/?s={search_term_string}`
    },
    "query-input": "required name=search_term_string"
  }
})} />
