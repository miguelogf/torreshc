---
import type { HTMLAttributes } from "astro/types";

type ButtonVariant = "primary" | "outline" | "ghost";
type ButtonType = "button" | "submit" | "reset";

type Props =
  | {
      id?: string;
      variant?: ButtonVariant;
      href: string;
      isNewTab?: boolean;
      isFullWidth?: boolean;
      isDisabled?: boolean;
      ariaLabel?: string;
      className?: string;
      anchorProps?: HTMLAttributes<"a">;
      buttonType?: never;
      htmlProps?: never;
    }
  | {
      id?: string;
      variant?: ButtonVariant;
      href?: never;
      isNewTab?: never;
      isFullWidth?: boolean;
      isDisabled?: boolean;
      ariaLabel?: string;
      className?: string;
      buttonType?: ButtonType;
      htmlProps?: HTMLAttributes<"button">;
      anchorProps?: never;
    };

const {
  id,
  variant = "primary",
  buttonType = "button",
  href,
  isNewTab = false,
  isFullWidth = false,
  isDisabled = false,
  ariaLabel,
  className = "",
  htmlProps = {},
  anchorProps = {},
} = Astro.props;

const isInteractive = href !== undefined;

const componentClass = [
  "button",
  `button--${variant}`,
  isFullWidth && "button--fullWidth",
  isDisabled && "button--disabled",
  className,
]
  .filter(Boolean)
  .join(" ");

const mergeClass = (externalClass?: string) =>
  [componentClass, externalClass].filter(Boolean).join(" ");

const sharedProps = {
  id: id,
  "aria-label": ariaLabel,
  "aria-disabled": isDisabled || undefined,
};
---

{
  isInteractive ? (
    <a
      href={isDisabled ? undefined : href}
      target={isNewTab ? "_blank" : undefined}
      rel={isNewTab ? "noopener noreferrer" : undefined}
      class={mergeClass(anchorProps.class as string)}
      {...sharedProps}
      {...anchorProps}
    >
      <slot />
    </a>
  ) : (
    <button
      type={buttonType}
      disabled={isDisabled}
      class={mergeClass(htmlProps.class as string)}
      {...sharedProps}
      {...htmlProps}
    >
      <slot />
    </button>
  )
}

<style>
  .button {
    box-sizing: border-box;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 8px 24px;
    font-size: 16px;
    font-weight: 500;
    border-radius: 999px;
    border: 1px solid transparent;
    cursor: pointer;
    text-decoration: none;
    transition-property:
      opacity, transform, background-color, border-color, color;
    transition-duration: 160ms;
    transition-timing-function: ease;
  }

  .button--primary {
    background-color: var(--color-primary);
    border-color: var(--color-primary);
    color: var(--color-white);
  }

  .button--outline {
    background-color: transparent;
    border-color: var(--color-dark);
    color: var(--color-dark);
  }

  .button--ghost {
    background-color: transparent;
    border-color: transparent;
    color: var(--color-dark);
    padding: 8px;
  }

  .button:hover:not(.button--disabled) {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  .button--ghost:hover:not(.button--disabled) {
    background-color: var(--color-muted);
  }

  .button:active:not(.button--disabled) {
    transform: translateY(0) scale(0.98);
  }

  .button:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .button--fullWidth {
    width: 100%;
  }

  .button--disabled {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
  }

  @media (max-width: 640px) {
    .button--fullWidth {
      width: 100%;
      min-width: 0;
    }
  }
</style>
