---
interface Props {
  class?: string;
  delay?: number;
  reveal?: boolean;
  interactive?: boolean;
}

const { 
  class: className, 
  delay = 0, 
  reveal = true, 
  interactive = true 
} = Astro.props;
---

<div 
  class:list={[
    "card-base", 
    reveal && "reveal-on-scroll", 
    interactive && "is-interactive",
    className // Aquí es donde entra "feat-item"
  ]} 
  style={delay ? `--delay: ${delay}ms` : ''}
>
  <slot />
</div>

<script>
const observer = new IntersectionObserver((entries) => {
  entries.forEach((entry) => {
    if (entry.isIntersecting) {
      entry.target.classList.add("revealed");
      observer.unobserve(entry.target);
    }
  });
}, { threshold: 0.15 });

// Observa las cards propias, no .feat-item
document.querySelectorAll(".reveal-on-scroll").forEach((el, i) => {
  (el as HTMLElement).style.transitionDelay = `${i * 80}ms`;
  observer.observe(el);
});
</script>

<style>
  .card-base {
    background: color-mix(in srgb, var(--text) 3%, transparent);
    border: 1px solid color-mix(in srgb, var(--text) 10%, transparent);
    border-radius: 14px;
    overflow: hidden;
    transition: 
    opacity 0.6s ease var(--delay, 0ms), 
    transform 0.6s ease var(--delay, 0ms), 
    border-color 0.2s ease, 
    background 0.2s ease;
  }

  .is-interactive:hover {
    border-color: color-mix(in srgb, var(--brand) 30%, transparent);
    background: color-mix(in srgb, var(--text) 5%, transparent);
    transform: translateY(-2px);
    cursor: pointer;
  }

  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(20px);
  }

  .reveal-on-scroll.revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>